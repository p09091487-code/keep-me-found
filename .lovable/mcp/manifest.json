{
  "version": 1,
  "sdk_version": "0.20.0",
  "path": "/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://zuqoxoisayelyyktmecn.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "phonetrack-mcp",
      "version": "0.1.0",
      "title": "PhoneTrack MCP"
    },
    "tools": [
      {
        "name": "list_devices",
        "title": "List my devices",
        "description": "List all phones the signed-in user has registered for tracking (alias, brand, model, IMEI, status).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "get_device_positions",
        "title": "Get device positions",
        "description": "Return the most recent GPS positions recorded for one of the signed-in user's devices.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "device_id": {
              "type": "string",
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
              "description": "Device UUID (from list_devices)."
            },
            "limit": {
              "default": 20,
              "description": "Max positions to return.",
              "type": "integer",
              "minimum": 1,
              "maximum": 200
            }
          },
          "required": [
            "device_id"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "update_device_status",
        "title": "Update device status",
        "description": "Mark one of the signed-in user's devices as safe, lost, or stolen.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "device_id": {
              "type": "string",
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
              "description": "Device UUID (from list_devices)."
            },
            "status": {
              "type": "string",
              "enum": [
                "safe",
                "lost",
                "stolen"
              ],
              "description": "New status for the device."
            }
          },
          "required": [
            "device_id",
            "status"
          ]
        },
        "outputSchema": null
      }
    ]
  }
}
